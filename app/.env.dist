GITLAB_URL=
GITLAB_TOKEN=
GITLAB_GROUP_ID=
GITLAB_SYNC_DATE_AFTER=
GITLAB_EXCLUDED_USER_IDS=
GITLAB_EXCLUDED_PROJECT_IDS=

GIT_LOG_EXCLUDE_PATH=composer.lock,package-lock.json,*.otf,*.eot,*.svg,*.ttf,*.woff,*.woff2,go.sum

REPORT_TESTED_LABELS=

# Merge Request Activity
POINTS_MERGE_REQUEST_CREATED=1.0
POINTS_APPROVALS_GIVEN=2.0

# Merged Merge Requests
POINTS_MERGE_REQUEST_MERGED=5.0
POINTS_MERGE_REQUEST_APPROVED=3.0
POINTS_MERGE_REQUEST_TESTED=2.0

# Lines of Code
POINTS_LINES_ADDED=0.001
POINTS_LINES_REMOVED=0.002

# Informational (displayed but not scored)
POINTS_SELF_APPROVALS=0.0
POINTS_DIRECT_COMMITS_TO_MAIN=0.0
